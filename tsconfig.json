{
    "compilerOptions": {
        "paths": {
            "actions": ["./src/actions"],
            "actions/*": ["./src/actions/*"],
            "config": ["./src/config"],
            "config/*": ["./src/config/*"],
            "helpers": ["./src/helpers"],
            "helpers/*": ["./src/helpers/*"],
            "hooks": ["./src/hooks"],
            "hooks/*": ["./src/hooks/*"],
            "locale": ["./src/locale"],
            "locale/*": ["./src/locale/*"],
            "middleware": ["./src/middleware"],
            "middleware/*": ["./src/middleware/*"],
            "modules": ["./src/modules"],
            "modules/*": ["./src/modules/*"],
            "mock": ["./src/mock"],
            "mock/*": ["./src/mock/*"],
            "reducer": ["./src/reducer"],
            "reducers": ["./src/reducers"],
            "reducers/*": ["./src/reducers/*"],
            "repositories": ["./src/repositories"],
            "repositories/*": ["./src/repositories/*"],
            "types/*": ["./src/@types/*"],
            "utils": ["./utils"],
            "utils/*": ["./utils/*"]
        },
        "target": "esnext",
        "jsx": "react-jsxdev",
        "module": "esnext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "allowJs": true,
        "checkJs": false,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": true,
        "types": ["node"],
        // for MUI types
        "lib": ["es2016", "dom"]
    },
    "include": ["src/**/*.tsx", "src/**/*.ts", "utils/**/*.ts"],
    "exclude": ["node_modules", "custom_modules", "/src/mocks/", "dist"]
}